EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Remote sync stays OFF until this is "true" (requires the Supabase tables + auth).
# The app is fully usable offline regardless.
EXPO_PUBLIC_ENABLE_REMOTE_SYNC=false

# Used only by Prisma tooling for the remote/design schema (not by the device app).
DATABASE_URL=postgresql://postgres:root@localhost.nest_keep:5432/public
